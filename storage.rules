rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /chats/{chatId}/{allPaths=**} {
      // Allow read/write if the user is authenticated and part of the chat
      // The chatId is [uid1, uid2].sort().join('_')
      allow read, write: if request.auth != null && 
        (request.auth.uid in chatId.split('_') || 
         request.auth.token.email.replace('.', '_') in chatId.split('_'));
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
